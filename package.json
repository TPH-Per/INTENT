{
  "name": "intent-monorepo",
  "version": "1.0.0",
  "description": "Autonomous Intent Management System",
  "private": true,
  "workspaces": [
    "core",
    "agents/*",
    "sensors",
    "dashboard",
    "registry"
  ],
  "scripts": {
    "test": "npm test --workspaces",
    "build": "npm run build --workspaces",
    "dev:infra": "docker compose -f infra/local/docker-compose.yml up -d",
    "dev:down": "docker compose -f infra/local/docker-compose.yml down",
    "migrate": "ts-node core/src/migrations/run.ts",
    "simulate": "ts-node scripts/simulate-e2e.ts",
    "typecheck": "tsc --noEmit",
    "dashboard": "cd dashboard && npm run dev",
    "start": "ts-node registry/src/index.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.76",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
